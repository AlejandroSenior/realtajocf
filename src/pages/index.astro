---
import Layout from '@/layouts/Layout.astro';
import TeamCarousel from '@/components/TeamCarousel.astro';
import LeaderBoard from '@/components/LeaderBoard.vue';
import TopScorers from '@/components/TopScorers.vue';
import LastMatch from '@/components/LastMatch.vue';
import Calendar from '@/components/Calendar.vue';
import Hero from '@/components/Hero.astro';
import Footer from '@/components/Footer.astro';
import Gallery from '@/components/Gallery.astro';
---

<Layout>
  <Hero />

  <div data-reveal>
    <TeamCarousel />
  </div>

  <main class="mx-auto max-w-6xl px-5 md:px-8">
    <section id="ultimo-resultado" class="scroll-mt-10 pt-24" data-reveal>
      <LastMatch client:only="vue">
        <template #fallback>
          <section aria-label="Último resultado">
            <header class="section-header items-center text-center">
              <p class="section-eyebrow">Marcador</p>
              <h2 class="section-title">Último resultado</h2>
              <p class="mt-1 flex justify-center" aria-hidden="true">
                <span class="skeleton h-4 w-40 rounded"></span>
              </p>
            </header>

            <div class="card-glass mx-auto max-w-4xl px-6 py-10 md:px-12" aria-hidden="true">
              <div class="flex items-center justify-center gap-4 md:gap-8">
                <div class="flex flex-1 flex-col items-center gap-3 md:flex-row md:justify-end">
                  <span class="skeleton order-2 h-5 w-28 rounded md:order-1"></span>
                  <span class="skeleton order-1 h-14 w-14 rounded-full md:order-2 md:h-18 md:w-18"></span>
                </div>

                <div class="flex shrink-0 items-center gap-1.5">
                  <span class="skeleton h-16 w-14 rounded md:h-20 md:w-20"></span>
                  <span class="skeleton h-16 w-14 rounded md:h-20 md:w-20"></span>
                </div>

                <div class="flex flex-1 flex-col items-center gap-3 md:flex-row md:justify-start">
                  <span class="skeleton h-14 w-14 rounded-full md:h-18 md:w-18"></span>
                  <span class="skeleton h-5 w-28 rounded"></span>
                </div>
              </div>
            </div>
          </section>
        </template>
      </LastMatch>
    </section>

    <section class="pt-24" data-reveal>
      <LeaderBoard client:only="vue">
        <template #fallback>
          <div>
            <header class="section-header">
              <p class="section-eyebrow">La liga</p>
              <h2 class="section-title">Clasificación</h2>
            </header>

            <div class="card-glass overflow-hidden p-2" aria-hidden="true">
              {Array.from({ length: 10 }).map(() => (
                <div class="flex items-center gap-3 border-b border-white/5 px-3 py-3 last:border-b-0">
                  <span class="skeleton h-7 w-7 shrink-0 rounded-md"></span>
                  <span class="skeleton h-4 w-28 max-w-[40%] flex-1 rounded"></span>
                  <span class="skeleton h-4 w-8 rounded"></span>
                  <span class="skeleton h-4 w-8 rounded"></span>
                  <span class="skeleton h-4 w-8 rounded"></span>
                  <span class="skeleton h-4 w-8 rounded"></span>
                </div>
              ))}
            </div>
          </div>
        </template>
      </LeaderBoard>
    </section>

    <section class="pt-24" data-reveal>
      <TopScorers client:only="vue">
        <template #fallback>
          <div>
            <header class="section-header">
              <p class="section-eyebrow">Goleadores</p>
              <h2 class="section-title">Estadísticas</h2>
            </header>

            <ol class="space-y-2.5" aria-hidden="true">
              {Array.from({ length: 5 }).map(() => (
                <li class="card-glass flex items-center gap-4 px-4 py-3 md:gap-6 md:px-6">
                  <span class="skeleton h-8 w-8 shrink-0 rounded-md"></span>

                  <div class="min-w-0 flex-1">
                    <div class="flex items-baseline justify-between gap-3">
                      <span class="skeleton h-4 w-32 max-w-[60%] rounded"></span>
                      <span class="skeleton h-3 w-20 shrink-0 rounded"></span>
                    </div>
                    <div class="skeleton mt-2 h-[5px] w-full rounded-full"></div>
                  </div>

                  <span class="skeleton h-9 w-9 shrink-0 rounded"></span>
                </li>
              ))}
            </ol>
          </div>
        </template>
      </TopScorers>
    </section>

    <section class="pt-24" data-reveal>
      <Calendar client:only="vue">
        <template #fallback>
          <div>
            <header class="section-header">
              <p class="section-eyebrow">Calendario</p>
              <h2 class="section-title">Próximos partidos</h2>
            </header>

            <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3" aria-hidden="true">
              {Array.from({ length: 3 }).map(() => (
                <div class="card-glass flex flex-col overflow-hidden">
                  <div class="flex items-center justify-between px-5 pt-4">
                    <span class="skeleton h-3 w-24 rounded"></span>
                    <span class="skeleton h-5 w-16 rounded-sm"></span>
                  </div>

                  <div class="flex items-center gap-5 px-5 py-6">
                    <div class="skeleton h-20 w-16 shrink-0 rounded-lg"></div>

                    <div class="min-w-0 flex-1 space-y-2.5">
                      <span class="skeleton block h-3.5 w-3/4 rounded"></span>
                      <span class="skeleton block h-3 w-6 rounded"></span>
                      <span class="skeleton block h-3.5 w-2/3 rounded"></span>
                    </div>
                  </div>

                  <div class="mt-auto border-t border-white/8 px-5 py-3">
                    <span class="skeleton inline-block h-3 w-32 rounded"></span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </template>
      </Calendar>
    </section>
  </main>

  <section class="pt-24" data-reveal>
    <Gallery />
  </section>

  <Footer />
</Layout>
