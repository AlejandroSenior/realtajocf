---
import Layout from '@/layouts/Layout.astro';
import TeamCarousel from '@/components/TeamCarousel.astro';
import LeaderBoard from '@/components/LeaderBoard.vue';
import TopScorers from '@/components/TopScorers.vue';
import LastMatch from '@/components/LastMatch.vue';
import Calendar from '@/components/Calendar.vue';
import Hero from '@/components/Hero.astro';
import Footer from '@/components/Footer.astro';
import Gallery from '@/components/Gallery.astro';
---

<Layout>
  <Hero />

  <div data-reveal>
    <TeamCarousel />
  </div>

  <main class="mx-auto max-w-6xl px-5 md:px-8">
    <section id="ultimo-resultado" class="scroll-mt-10 pt-24" data-reveal>
      <LastMatch client:only="vue">
        <template #fallback>
          <div class="py-10 text-center text-white/50">Cargando último resultado...</div>
        </template>
      </LastMatch>
    </section>

    <section class="pt-24" data-reveal>
      <LeaderBoard client:only="vue">
        <template #fallback>
          <div class="py-10 text-center text-white/50">Cargando clasificación...</div>
        </template>
      </LeaderBoard>
    </section>

    <section class="pt-24" data-reveal>
      <TopScorers client:only="vue">
        <template #fallback>
          <div class="py-10 text-center text-white/50">Cargando estadísticas de goleadores...</div>
        </template>
      </TopScorers>
    </section>

    <section class="pt-24" data-reveal>
      <Calendar client:only="vue">
        <template #fallback>
          <div class="py-10 text-center text-white/50">Cargando calendario...</div>
        </template>
      </Calendar>
    </section>
  </main>

  <section class="pt-24" data-reveal>
    <Gallery />
  </section>

  <Footer />
</Layout>
